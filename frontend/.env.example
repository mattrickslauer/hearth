# Hearth demo — Qwen Cloud wiring.
#
# With NONE of these set, the /demo brain runs a deterministic in-browser mock,
# so the demo works with zero setup. Set the two starred vars to make it call
# Qwen Cloud for real (authoring + runtime judgement).

# ── server-side only (held by the /qwen API route, never shipped to the browser)
QWEN_API_KEY=                                     # ★ your Qwen Cloud / DashScope key
QWEN_MODEL=qwen-plus                              #   text model for authoring + judging
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions

# ── client-side (EXPO_PUBLIC_ is bundled into the app)
EXPO_PUBLIC_USE_QWEN=0                            # ★ set to 1 to route the brain through /qwen

# ── client-side backend base URL for auth (defaults to the deployed FC function)
EXPO_PUBLIC_BACKEND_URL=...

# ── realtime: nothing to configure here. The dashboard auto-discovers the account's hub and
# opens a secure cloud-brokered WebSocket (the relay at hub-ws.agfarms.dev) via GET
# /live/ticket on the backend. It's driven entirely by the backend's RELAY_* env (see
# backend/.env.example + backend/docs/realtime-relay.md); when that's unset, the dashboard
# falls back to load-on-mount + manual refresh. No EXPO_PUBLIC_* var is needed for realtime.
