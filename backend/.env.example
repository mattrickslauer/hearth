# Copy to backend/.env (gitignored) and fill in. Only AUTH_SESSION_SECRET is required.
#
# AUTH_SESSION_SECRET — HMAC key for session tokens. REQUIRED (>=16 chars); the server
# refuses to boot without it (no fallback). Use the SAME value in dev and prod; keep it
# in the deploy env too. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SESSION_SECRET=

# Qwen (Model Studio / DashScope) — the brain. Unset → mock brain.
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus

# ZeptoMail SMTP — send real OTP emails. Unset → code logged to server console (dev).
# ZEPTOMAIL_SMTP_PASS=
# ZEPTOMAIL_FROM=hearth@agfarms.dev

# Tablestore — durable signups (accounts + OTP) in production. HEARTH_STORE=tablestore
# flips both; needs the tables from backend/README.md ("Make it real" §2) + these keys.
# Unset → in-memory (lost on restart). Use HEARTH_STORE=file for persistent local dev.
# HEARTH_STORE=tablestore
# TABLESTORE_ENDPOINT=https://<instance>.<region>.ots.aliyuncs.com
# TABLESTORE_INSTANCE=<instance-name>
# ALI_ACCESS_KEY_ID=
# ALI_ACCESS_KEY_SECRET=

# Realtime — cloud-brokered live sensor stream to the dashboard over Alibaba API Gateway's
# WebSocket. Unset → realtime is OFF (dashboard uses load-on-mount + manual refresh; nothing
# breaks). Provisioning (create the WS API group, REGISTER/NOTIFY/UNREGISTER apis, an App)
# is in docs/realtime-apigateway.md — it yields these four values. For correct multi-instance
# behaviour on FC, run with HEARTH_STORE=tablestore so the connection registry is shared.
# APIGW_WS_URL=wss://<group-independent-domain>:8443   # secure port — VERIFY against your gateway
# APIGW_NOTIFY_URL=https://<group-host>/<notify-api-path>
# APIGW_APP_KEY=
# APIGW_APP_SECRET=
