# Copy to backend/.env (gitignored) and fill in. Only AUTH_SESSION_SECRET is required.
#
# AUTH_SESSION_SECRET — HMAC key for session tokens. REQUIRED (>=16 chars); the server
# refuses to boot without it (no fallback). Use the SAME value in dev and prod; keep it
# in the deploy env too. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SESSION_SECRET=

# Qwen (Model Studio / DashScope) — the brain. Unset → mock brain.
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus

# CORS — comma-separated allowlist of app origins. Unset → '*' (open, back-compat).
# Set to your deployed frontend origin(s); list the primary app origin first.
# CORS_ORIGINS=https://hearth.vercel.app,http://localhost:8081

# ZeptoMail SMTP — send real OTP emails. Unset → code logged to server console (dev).
# ZEPTOMAIL_SMTP_PASS=
# ZEPTOMAIL_FROM=hearth@agfarms.dev

# Tablestore — durable signups (accounts + OTP) in production. HEARTH_STORE=tablestore
# flips both; needs the tables from backend/README.md ("Make it real" §2) + these keys.
# Unset → in-memory (lost on restart). Use HEARTH_STORE=file for persistent local dev.
# HEARTH_STORE=tablestore
# TABLESTORE_ENDPOINT=https://<instance>.<region>.ots.aliyuncs.com
# TABLESTORE_INSTANCE=<instance-name>
# ALI_ACCESS_KEY_ID=
# ALI_ACCESS_KEY_SECRET=

# Realtime — cloud-brokered live sensor stream to the dashboard via the always-on relay
# (relay/relay.mjs, deployed at hub-ws.agfarms.dev). Unset → realtime is OFF (dashboard uses
# load-on-mount + manual refresh; nothing breaks). See docs/realtime-relay.md for the setup.
# RELAY_PUBLISH_SECRET must match the value the relay runs with; it also verifies the browser
# ticket using AUTH_SESSION_SECRET, so that value must be identical on the backend and relay.
# RELAY_WS_URL=wss://hub-ws.agfarms.dev/live         # what the browser connects to
# RELAY_PUBLISH_URL=https://hub-ws.agfarms.dev/publish   # where the backend pushes readings
# RELAY_PUBLISH_SECRET=
