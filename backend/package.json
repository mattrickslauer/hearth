{
  "name": "hearth-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hearth cloud backend — the Home MCP server + Qwen orchestration, deployable to Alibaba Function Compute.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "smoke": "tsx scripts/smoke.ts",
    "qwen-check": "tsx scripts/qwen-check.ts",
    "qwen-vl-check": "tsx scripts/qwen-vl-check.ts",
    "oss-provision": "tsx scripts/oss-provision.ts",
    "household-check": "tsx scripts/household-check.ts",
    "vision-watch-check": "tsx scripts/vision-watch-check.ts",
    "oss-check": "tsx scripts/oss-check.ts",
    "readings-check": "tsx scripts/readings-check.ts",
    "hub-devices-check": "tsx scripts/hub-devices-check.ts",
    "mail-check": "tsx scripts/mail-check.ts",
    "notify-check": "tsx scripts/notify-check.ts",
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs",
    "pricing-check": "tsx scripts/pricing-check.ts"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
